Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SYSTEM", " ", "1"}], ":", " ", 
    RowBox[{"1", "-", 
     RowBox[{"Dimensional", " ", "Spring"}]}]}], "\[IndentingNewLine]", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", "Constants", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"m", "=", "1"}], ";"}], "  ", 
   RowBox[{"(*", "mass", "*)"}], "\n", 
   RowBox[{
    RowBox[{"k", "=", "1"}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"spring", " ", "constant"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"x0", "=", "0"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"equilibrium", " ", "position"}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "conditions"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"x", "=", "1"}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"initial", " ", "position"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"v", "=", "0"}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"initial", " ", "velocity"}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Time", " ", "step"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"dt", "=", "0.01"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Simulation", " ", "time"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tMax", "=", "100"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Force", " ", "function"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"F", "[", "x_", "]"}], ":=", 
    RowBox[{
     RowBox[{"-", "k"}], " ", 
     RowBox[{"(", 
      RowBox[{"x", "-", "x0"}], ")"}]}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Energy", " ", "function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"En", "[", 
     RowBox[{"x_", ",", "v_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"0.5", "*", "m", "*", 
      RowBox[{"v", "^", "2"}]}], "+", 
     RowBox[{"0.5", "*", "k", "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "-", "x0"}], ")"}], "^", "2"}]}]}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Verlet", " ", 
       RowBox[{"Algorithm", ":", "\[IndentingNewLine]", 
        RowBox[{"Syntax", " ", "Notes", "\[IndentingNewLine]", "x_"}], ":", 
        " ", 
        RowBox[{
        "underscore", " ", "denotes", " ", "this", " ", "is", " ", "a", " ", 
         RowBox[{"Generic", "."}]}]}]}], "\[IndentingNewLine]", "    ", ":=", 
      " ", 
      RowBox[{"denotes", " ", "lazy", " ", "evaluation"}]}], ";", " ", 
     RowBox[{"necessary", " ", "for", " ", "function", " ", "definitions"}]}],
     "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"velocityVerlet", "[", 
     RowBox[{"x_", ",", "v_", ",", "dt_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"newX", ",", " ", "newV", ",", " ", "fOld", ",", " ", "fNew"}],
        "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"fOld", " ", "=", " ", 
        RowBox[{"F", "[", "x", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"newX", " ", "=", " ", 
        RowBox[{"x", " ", "+", " ", 
         RowBox[{"v", " ", "*", " ", "dt"}], " ", "+", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}], " ", "*", " ", 
          RowBox[{"f1", "/", "m"}], " ", "*", " ", 
          RowBox[{"dt", "^", "2"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"fNew", " ", "=", " ", 
        RowBox[{"F", "[", "newX", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"newV", " ", "=", " ", 
        RowBox[{"v", "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"dt", "*", 
            RowBox[{"(", 
             RowBox[{"fOld", " ", "+", " ", "fNew"}], ")"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", "m"}], ")"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"newX", ",", "newV"}], "}"}]}]}], "\[IndentingNewLine]", 
     "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Run", " ", "simulation"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{
      RowBox[{"Reap", "[", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"x", ",", "v"}], "}"}], "=", 
           RowBox[{"velocityVerlet", "[", 
            RowBox[{"x", ",", "v", ",", "dt"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Sow", "[", 
           RowBox[{"{", 
            RowBox[{"t", ",", "x", ",", "v", ",", 
             RowBox[{"E", "[", 
              RowBox[{"x", ",", "v"}], "]"}]}], "}"}], "]"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"t", ",", "0", ",", "tMax", ",", "dt"}], "}"}]}], 
        "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.928593571875561*^9, 3.92859358885186*^9}, 
