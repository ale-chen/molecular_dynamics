Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Check", " ", "if", " ", "std", 
     RowBox[{"(", "E", ")"}]}], "\[Proportional]", 
    RowBox[{"dt", "^", "2"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"dtValues", "=", 
     RowBox[{"{", 
      RowBox[{"0.001", ",", "0.005", ",", "0.01", ",", "0.05", ",", "0.1"}], 
      "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"stdEnergies", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "v"}], "}"}], "=", 
         RowBox[{"{", 
          RowBox[{"1", ",", "0"}], "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"energies", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"x", ",", "v"}], "}"}], "=", 
             RowBox[{"velocityVerlet", "[", 
              RowBox[{"x", ",", "v", ",", "dt"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"E", "[", 
             RowBox[{"x", ",", "v"}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "0", ",", "tMax", ",", "dt"}], "}"}]}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"dt", ",", 
          RowBox[{"StandardDeviation", "[", "energies", "]"}]}], "}"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"dt", ",", "dtValues"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"ListLogLogPlot", "[", 
    RowBox[{"stdEnergies", ",", "\[IndentingNewLine]", 
     RowBox[{
     "PlotLabel", "->", "\"\<Energy Standard Deviation vs Time Step\>\""}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<dt\>\"", ",", "\"\<std(E)\>\""}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Epilog", "->", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
